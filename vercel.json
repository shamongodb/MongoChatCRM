{
  "installCommand": "npm install",
  "buildCommand": "npm run sync:public",
  "outputDirectory": "public",
  "functions": {
    "api/index.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/mcp.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/config.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/mcp",
      "destination": "/api/mcp"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/config.js",
      "destination": "/api/index"
    },
    {
      "source": "/app.js",
      "destination": "/app.js"
    },
    {
      "source": "/styles.css",
      "destination": "/styles.css"
    },
    {
      "source": "/favicon.png",
      "destination": "/favicon.png"
    },
    {
      "source": "/auth.js",
      "destination": "/auth.js"
    },
    {
      "source": "/login.js",
      "destination": "/login.js"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
