PORT=8787
WEB_UX_PORT=8790
NODE_API_BASE_URL=http://localhost:8787
NODE_API_KEY=
REQUIRE_NODE_API_KEY=false
GOOGLE_CLIENT_ID=
JWT_SIGNING_SECRET=
JWT_ISSUER=mcp-node-api
JWT_AUDIENCE=mongiecrm-app
JWT_EXPIRY_SECONDS=3600
CORS_ALLOWED_ORIGINS=
AZURE_API_KEY=
AZURE_ENDPOINT=
GAS_WEB_APP_URL=
NODE_TO_GAS_SECRET=
MONGO_URI=
MONGO_DB_NAME=sales_data
MONGO_TASK_LISTS_COLLECTION=taskLists
MONGO_TASKS_COLLECTION=tasks
MONGO_CONTACTS_COLLECTION=contacts
MONGO_ACCOUNTS_COLLECTION=accounts
MONGO_WORKLOADS_COLLECTION=Workloads
MONGO_MILESTONES_COLLECTION=milestones
MONGO_INITIATIVES_COLLECTION=initiatives
# Voyage AI embeddings (initiative name + optional future account/contact name vectors)
MONGO_VOYAGE_API_KEY=
# Optional; default voyage-3-large
MONGO_VOYAGE_EMBED_MODEL=voyage-3-large
# Optional; when set, embedding length must match (e.g. 1024 for voyage-3-large)
MONGO_VOYAGE_EMBED_DIMENSIONS=
# Atlas Search index name for $vectorSearch on initiatives.initiativeNameEmbedding
MONGO_INITIATIVES_VECTOR_INDEX=initiatives_vector
MONGO_CONVERSATIONS_COLLECTION=conversations
MONGO_MESSAGES_COLLECTION=messages
MONGO_MEMORY_SUMMARIES_COLLECTION=memory_summaries
MONGO_MEMORY_JOBS_COLLECTION=memory_jobs
MONGO_AUTH_USERS_COLLECTION=auth_users
MEMORY_RECENT_MESSAGES=12
MEMORY_SUMMARY_THRESHOLD_MESSAGES=10
MEMORY_SUMMARY_BATCH_SIZE=50
MEMORY_SUMMARY_RETRIES=2
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-01

# LLM provider: azure (default) | grok
LLM_PROVIDER=azure
# xAI / Grok (required when LLM_PROVIDER=grok)
XAI_API_KEY=
XAI_MODEL=grok-4.3
XAI_REASONING_EFFORT=low

# xAI Voice Agent (mic button) + MongoDB MCP
XAI_VOICE_ID=
# Public HTTPS URL for MCP (production). Local dev can omit — derived from Host header.
MCP_PUBLIC_URL=
# voice provider for mic: xai (default) | elevenlabs
VOICE_PROVIDER=xai

# ElevenLabs (legacy /api/voice/* — not used by mic when VOICE_PROVIDER=xai)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Optional: pin Scribe model for speech-to-text; omit for ElevenLabs default
ELEVENLABS_STT_MODEL_ID=
# Optional: defaults to eleven_turbo_v2
ELEVENLABS_TTS_MODEL_ID=
