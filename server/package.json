{
  "name": "mcp-node-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "concurrently -k -n API,WEB \"npm run start:api\" \"npm --prefix ../web-ux start\"",
    "start:api": "node src/index.js",
    "check": "node --check src/index.js",
    "test": "node --test",
    "migrate:workloads:structured": "node scripts/backfill-workload-structured-fields.js",
    "migrate:tasks:documents": "node scripts/migrate-task-lists-to-task-documents.js",
    "migrate:tasks:documents:execute": "node scripts/migrate-task-lists-to-task-documents.js --execute --assert",
    "migrate:audit:backfill": "node scripts/backfill-crm-audit-fields.js",
    "migrate:audit:backfill:execute": "node scripts/backfill-crm-audit-fields.js --execute"
  },
  "dependencies": {
    "@langchain/core": "^0.3.79",
    "@langchain/langgraph": "^0.2.74",
    "@langchain/openai": "^0.6.16",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "google-auth-library": "^10.7.0",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^0.3.36",
    "mongodb": "^6.12.0",
    "multer": "^2.0.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
